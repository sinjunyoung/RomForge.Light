<Window x:Class="RomForge.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RomForge.Views"
        xmlns:patch="clr-namespace:RomForge.Controls.Patch"
        xmlns:ps="clr-namespace:RomForge.Controls.PS"
        xmlns:util="clr-namespace:RomForge.Controls.Util"
        xmlns:settings="clr-namespace:RomForge.Controls.Settings"
        xmlns:vm="clr-namespace:RomForge.ViewModels"
        xmlns:helpers="clr-namespace:RomForge.Core.UI.Helpers;assembly=RomForge.Core"
        Title="{Binding AppVersion}"
        Height="720" Width="900"
        MinHeight="480" MinWidth="900"
        Background="#1E1E1E"
        AllowDrop="True"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="340"/>
            <RowDefinition Height="5"/>
            <RowDefinition x:Name="LogRow" Height="{Binding LogBoxHeight}" MinHeight="40"/>
        </Grid.RowDefinitions>

        <TabControl SelectedIndex="{Binding SelectedTabIndex}">

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/Patch.png" Width="16" Height="16" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="패치" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <patch:MainTab/>
            </TabItem>

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/PS1.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="PSP" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ps:MainTab DataContext="{Binding PSMainVM}"/>
            </TabItem>

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/Utility.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="유틸" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <util:MainTab DataContext="{Binding UtilMainVM}"/>
            </TabItem>

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/Settings.png" Width="16" Height="16" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="설정" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <settings:MainTab DataContext="{Binding Settings}"/>
            </TabItem>

        </TabControl>

        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Cursor="SizeNS"
              DragCompleted="GridSplitter_DragCompleted">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Setter Property="Background" Value="#3A3A3A"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0078D4"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter Property="Background" Value="#005A9E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>

        <Border BorderBrush="#444444" BorderThickness="1" CornerRadius="10" Background="Transparent" Grid.Row="2">
            <RichTextBox x:Name="logBox" Style="{StaticResource LogBox}" helpers:RichTextBoxLogger.LogEntries="{Binding ActiveLogEntries}" BorderThickness="0" Background="Transparent" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"/>
        </Border>
    </Grid>
</Window>