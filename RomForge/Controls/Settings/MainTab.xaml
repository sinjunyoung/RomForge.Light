<UserControl x:Class="RomForge.Controls.Settings.MainTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RomForge.Controls.Settings">
    <Grid>
        <TabControl SelectedIndex="{Binding SubTabIndex, Mode=TwoWay}">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/Patch.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="패치" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <local:PatchSettingsTab DataContext="{Binding Patch}"/>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/PS1.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="PSX" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <local:PS1SettingsTab DataContext="{Binding PS1}"/>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>