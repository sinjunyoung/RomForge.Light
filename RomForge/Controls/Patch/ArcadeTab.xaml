<UserControl x:Class="RomForge.Controls.Patch.ArcadeTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RomForge.Controls.Patch"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Margin="2,0,2,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border IsEnabled="{Binding IsIdle}" Grid.Column="0" Style="{StaticResource DropZone}" AllowDrop="True" Drop="ArcadeSourceDrop_Drop">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/ZipFile.png" Width="28" Height="28" Margin="0,0,6,0" VerticalAlignment="Center" ToolTip="{Binding PatchVM.ArcadeVM.SourcePath}"/>
                        <TextBlock Text="{Binding PatchVM.ArcadeVM.SourceLabel}" Foreground="#888888" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,8,0,0" ToolTip="{Binding PatchVM.ArcadeVM.SourcePath}"/>
                    </StackPanel>
                    <TextBlock Text="원본 ZIP" Foreground="#888" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8" ToolTip="{Binding PatchVM.ArcadeVM.SourcePath}"/>
                </Grid>
            </Border>

            <Border IsEnabled="{Binding IsIdle}" Grid.Column="2" Style="{StaticResource DropZone}" AllowDrop="True" Drop="ArcadePatchDrop_Drop">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/ZipFolder.png" Width="28" Height="28" Margin="0,0,6,0" VerticalAlignment="Center" ToolTip="{Binding PatchVM.ArcadeVM.PatchPath}"/>
                        <TextBlock Text="{Binding PatchVM.ArcadeVM.PatchLabel}" Foreground="#888888" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,8,0,0" ToolTip="{Binding PatchVM.ArcadeVM.PatchPath}"/>
                    </StackPanel>
                    <TextBlock Text="패치(IPS/폴더/ZIP)" Foreground="#888" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8" ToolTip="{Binding PatchVM.ArcadeVM.PatchPath}"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="4,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="패치 선택:" Foreground="#DCDCDC" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>

            <ComboBox Grid.Column="1" Height="22" Padding="2,0" FontSize="11" VerticalAlignment="Center" 
                                  ItemsSource="{Binding DataContext.PatchVM.ArcadeVM.AvailablePatchPackages, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                  DisplayMemberPath="DisplayName" 
                                  SelectedItem="{Binding DataContext.PatchVM.ArcadeVM.SelectedPatchPackage, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                  SelectionChanged="PatchPicker_SelectionChanged"  Tag="{Binding}" ToolTip="다른 패치 패키지로 변경">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>
        </Grid>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding PatchVM.ArcadeVM.MatchItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="2,2" Padding="5,5" CornerRadius="4" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="3" Padding="8,4" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SourceFileName}" Foreground="#DCDCDC" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding SourceFileName}"/>
                                    </Border>

                                    <TextBlock Grid.Column="1" Text="→" Foreground="#555555" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                    <Border Grid.Column="2" AllowDrop="True" Drop="MatchCard_PatchDrop" DragOver="MatchCard_DragOver" Tag="{Binding}" CornerRadius="3" Padding="8,4" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1E1E1E"/>
                                                <Setter Property="BorderBrush" Value="#3F3F46"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PatchFileName}" Value="{x:Null}">
                                                        <Setter Property="BorderBrush" Value="#FF6B6B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding PatchFileName}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding PatchFileName}"/>
                                                    <Setter Property="Foreground" Value="#DCDCDC"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PatchFileName}" Value="{x:Null}">
                                                            <Setter Property="Text" Value="패치 파일을 드래그&amp;드롭하세요"/>
                                                            <Setter Property="Foreground" Value="#555555"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <ComboBox Grid.Column="3" Width="140" Height="22" Margin="4,0,0,0" Padding="2,0" FontSize="11" VerticalAlignment="Center" 
                                                          ItemsSource="{Binding DataContext.PatchVM.ArcadeVM.AllPatchEntries, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                          DisplayMemberPath="DisplayName" SelectedItem="{Binding PatchEntry, Mode=OneWay}" SelectionChanged="PatchPicker_SelectionChanged" Tag="{Binding}" ToolTip="다른 패치 파일로 변경">
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Foreground" Value="White"/>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                    </ComboBox>

                                    <Border Grid.Column="4" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2D7D46"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMatched}" Value="False">
                                                        <Setter Property="Background" Value="#7D2D2D"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontWeight="Bold" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="매칭"/>
                                                    <Setter Property="Foreground" Value="#AAFFAA"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMatched}" Value="False">
                                                            <Setter Property="Text" Value="미매칭"/>
                                                            <Setter Property="Foreground" Value="#FFAAAA"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <TextBlock Grid.Column="5" Text="{Binding MismatchReason}" Visibility="{Binding MismatchVisibility}" FontSize="10" VerticalAlignment="Center" Margin="5,0,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding MismatchReason}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFAAAA"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MismatchReason}" Value="CRC 일치">
                                                        <Setter Property="Foreground" Value="Green"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Grid Grid.Column="6" Margin="6,0,0,0">
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Style="{StaticResource ProgressBarStyle}" Height="20"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Progress}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="%" Foreground="White" FontSize="10" FontWeight="Bold" Margin="1,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" IsHitTestVisible="False" Visibility="{Binding PatchVM.ArcadeVM.HintVisibility}" BorderBrush="#333337" BorderThickness="1" CornerRadius="6" Margin="0,4,0,2">
            <Border.Background>
                <SolidColorBrush Color="#181818" Opacity="0.95"/>
            </Border.Background>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.90">
                <Image Source="/Assets/Images/Info.png" Width="28" Height="28" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="원본 ZIP, 패치(IPS, 폴더, ZIP)를 위에 드래그&amp;드롭하세요" Foreground="LightGray" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="확장자 기준으로 자동 매칭됩니다" Foreground="#888" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="0,1,0,0" CornerRadius="8" Margin="0,0,0,2" Padding="8,0">
            <Grid Height="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding PatchVM.ArcadeVM.ProgressSummary}" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Column="1" Margin="0,0,10,0" Text="{Binding PatchVM.ArcadeVM.TotalProgressText}" Foreground="#4CAF50" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>

                <Grid Grid.Column="2" Height="10" VerticalAlignment="Center">
                    <Border Background="#25FFFFFF" CornerRadius="5"/>
                    <Border CornerRadius="5" ClipToBounds="True">
                        <Border Background="#4CAF50" CornerRadius="5" RenderTransformOrigin="0,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="{Binding PatchVM.ArcadeVM.TotalProgress, Converter={StaticResource ProgressToStarConverter}, FallbackValue=0}"/>
                            </Border.RenderTransform>
                        </Border>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
    
</UserControl>
