<UserControl x:Class="RomForge.Controls.Patch.DreamcastTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Margin="2,0,2,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border IsEnabled="{Binding IsIdle}" Grid.Column="0" Style="{StaticResource DropZone}" AllowDrop="True" Drop="DreamcastSourceDrop_Drop" MouseLeftButtonDown="DreamcastSourceDrop_Click">
                <Grid Margin="14,0">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="/Assets/Images/AddFile.png" Width="28" Height="28" Margin="0,0,6,0" VerticalAlignment="Center" ToolTip="{Binding PatchVM.DreamcastVM.SourcePath}"/>
                        <TextBlock Grid.Column="1" Text="{Binding PatchVM.DreamcastVM.SourceLabel}" Foreground="#888888" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip="{Binding PatchVM.DreamcastVM.SourcePath}"/>
                    </Grid>
                    <TextBlock Text="원본 GDI" Foreground="#888" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8" ToolTip="{Binding PatchVM.DreamcastVM.SourcePath}"/>
                </Grid>
            </Border>
            <Border IsEnabled="{Binding IsIdle}" Grid.Column="2" Style="{StaticResource DropZone}" AllowDrop="True" Drop="DreamcastPatchDrop_Drop" MouseLeftButtonDown="DreamcastPatchDrop_Click">
                <Grid Margin="14,0">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="/Assets/Images/Patch.png" Width="28" Height="28" Margin="0,0,6,0" VerticalAlignment="Center" ToolTip="{Binding PatchVM.DreamcastVM.PatchPath}"/>
                        <TextBlock Grid.Column="1" Text="{Binding PatchVM.DreamcastVM.PatchLabel}" Foreground="#888888" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip="{Binding PatchVM.DreamcastVM.PatchPath}"/>
                    </Grid>
                    <TextBlock Text="DCP 패치" Foreground="#888" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8" ToolTip="{Binding PatchVM.DreamcastVM.PatchPath}"/>
                </Grid>
            </Border>
        </Grid>

        <ToggleButton Grid.Row="2" Style="{StaticResource ToggleStyle}" IsChecked="{Binding PatchVM.DreamcastVM.AutoCompress}" Margin="0,2,0,2">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Width="18" Margin="0,0,10,0" Source="{Binding PatchVM.DreamcastVM.AutoCompress, Converter={StaticResource BoolToImageConverter}}" VerticalAlignment="Center"/>
                <TextBlock Text="패치 후 CHD로 자동 압축" VerticalAlignment="Center" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,0,12,0"/>
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#1A4D56B2" BorderBrush="#4D4D56B2" BorderThickness="1" CornerRadius="5" Padding="6,2" Margin="0,0,4,0">
                            <TextBlock Text="GDI" Foreground="#8FA3FF" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#8FA3FF" Opacity="0.4"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="➔" Foreground="#FF9800" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="2,0,4,0"/>
                        <Border Background="#1A9E5B24" BorderBrush="#559E5B24" BorderThickness="1" CornerRadius="5" Padding="6,2">
                            <TextBlock Text="CHD" Foreground="#FFA254" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#FFA254" Opacity="0.4"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ToggleButton>

        <Border Grid.Row="4" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="0,1,0,0" CornerRadius="8" Margin="0,0,0,2" Padding="8,0">
            <Grid Height="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding PatchVM.DreamcastVM.ProgressStatus}" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Margin="0,0,10,0" Text="{Binding PatchVM.DreamcastVM.ProgressText}" Foreground="#4CAF50" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                <Grid Grid.Column="2" Height="10" VerticalAlignment="Center">
                    <Border Background="#25FFFFFF" CornerRadius="5"/>
                    <Border CornerRadius="5" ClipToBounds="True">
                        <Border Background="#4CAF50" CornerRadius="5" RenderTransformOrigin="0,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="{Binding PatchVM.DreamcastVM.Progress, Converter={StaticResource ProgressToStarConverter}, FallbackValue=0}"/>
                            </Border.RenderTransform>
                        </Border>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
    
</UserControl>